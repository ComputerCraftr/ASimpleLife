#include <inttypes.h>
#include <stdckdint.h>
#include <stddef.h>
#include <stdint.h>
#include <stdio.h>

static uint64_t bf_bits_mask(unsigned bits) {
    return bits == 0 ? UINT64_C(0) : ((UINT64_C(1) << bits) - 1);
}

static int64_t bf_wrap_from_u64_signed(uint64_t raw, unsigned bits) {
    if (bits == 0)
        return 0;
    raw &= bf_bits_mask(bits);
    if (bits == 63) {
        uint64_t sign = UINT64_C(1) << 62;
        if ((raw & sign) == 0) {
            return (int64_t)raw;
        }
        uint64_t mag = raw - sign;
        return (int64_t)mag - (int64_t)sign;
    }
    uint64_t sign = UINT64_C(1) << (bits - 1);
    if ((raw & sign) == 0) {
        return (int64_t)raw;
    }
    return (int64_t)raw - (int64_t)(UINT64_C(1) << bits);
}

static int64_t bf_wrap_from_u64_unsigned(uint64_t raw, unsigned bits) {
    if (bits == 0)
        return 0;
    return (int64_t)(raw & bf_bits_mask(bits));
}

static uint64_t bf_wrap_to_u64(int64_t value, unsigned bits) {
    if (bits == 0)
        return UINT64_C(0);
    return ((uint64_t)value) & bf_bits_mask(bits);
}

static int64_t bf_wrap_add_i64_signed(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_add(&out, ua, ub)) {
        out = ua + ub;
    }
    return bf_wrap_from_u64_signed(out, bits);
}

static int64_t bf_wrap_sub_i64_signed(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_sub(&out, ua, ub)) {
        out = ua - ub;
    }
    return bf_wrap_from_u64_signed(out, bits);
}

static int64_t bf_wrap_mul_i64_signed(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_mul(&out, ua, ub)) {
        out = ua * ub;
    }
    return bf_wrap_from_u64_signed(out, bits);
}

static int64_t bf_wrap_add_i64_unsigned(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_add(&out, ua, ub)) {
        out = ua + ub;
    }
    return bf_wrap_from_u64_unsigned(out, bits);
}

static int64_t bf_wrap_sub_i64_unsigned(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_sub(&out, ua, ub)) {
        out = ua - ub;
    }
    return bf_wrap_from_u64_unsigned(out, bits);
}

static int64_t bf_wrap_mul_i64_unsigned(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_mul(&out, ua, ub)) {
        out = ua * ub;
    }
    return bf_wrap_from_u64_unsigned(out, bits);
}

static _Noreturn void bf_diverge_forever(void) {
    static volatile int bf_diverge_sink = 0;
    for (;;) {
        bf_diverge_sink = 1;
    }
}

/* @BF_WRAP_PTR_BEGIN */
static ptrdiff_t bf_wrap_ptr(ptrdiff_t ptr, ptrdiff_t delta, ptrdiff_t len) {
    if (len <= 0)
        return 0;
    ptr %= len;
    if (ptr < 0)
        ptr += len;
    delta %= len;
    if (delta < 0)
        delta += len;
    return (ptr + delta) % len;
}
/* @BF_WRAP_PTR_END */

