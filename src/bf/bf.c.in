#include <inttypes.h>
#include <stdatomic.h>
#include <stdckdint.h>
#include <stddef.h>
#include <stdint.h>
#include <stdio.h>

/* @BF_CONFIG */

#ifndef BF_TEMPLATE_TAPE_LEN
#define BF_TEMPLATE_TAPE_LEN 30000
#endif

#ifndef BF_TEMPLATE_CELL_BITS
#define BF_TEMPLATE_CELL_BITS 8
#endif

#ifndef BF_TEMPLATE_SIGNED_CELLS
#define BF_TEMPLATE_SIGNED_CELLS 1
#endif

#ifndef BF_TEMPLATE_CELL_MASK
#define BF_TEMPLATE_CELL_MASK UINT64_C(255)
#endif

#ifndef BF_TEMPLATE_INPUT_MASK
#define BF_TEMPLATE_INPUT_MASK UINT64_C(255)
#endif

#ifndef BF_TEMPLATE_OUTPUT_MASK
#define BF_TEMPLATE_OUTPUT_MASK UINT64_C(255)
#endif

#define BF_MAYBE_UNUSED [[maybe_unused]]

BF_MAYBE_UNUSED static uint64_t bf_bits_mask(unsigned bits) {
    return bits == 0 ? UINT64_C(0) : ((UINT64_C(1) << bits) - 1);
}

BF_MAYBE_UNUSED static int64_t bf_wrap_from_u64_signed(uint64_t raw, unsigned bits) {
    if (bits == 0)
        return 0;
    raw &= bf_bits_mask(bits);
    if (bits == 63) {
        uint64_t sign = UINT64_C(1) << 62;
        if ((raw & sign) == 0) {
            return (int64_t)raw;
        }
        uint64_t mag = raw - sign;
        return (int64_t)mag - (int64_t)sign;
    }
    uint64_t sign = UINT64_C(1) << (bits - 1);
    if ((raw & sign) == 0) {
        return (int64_t)raw;
    }
    return (int64_t)raw - (int64_t)(UINT64_C(1) << bits);
}

BF_MAYBE_UNUSED static int64_t bf_wrap_from_u64_unsigned(uint64_t raw, unsigned bits) {
    if (bits == 0)
        return 0;
    return (int64_t)(raw & bf_bits_mask(bits));
}

BF_MAYBE_UNUSED static uint64_t bf_wrap_to_u64(int64_t value, unsigned bits) {
    if (bits == 0)
        return UINT64_C(0);
    return ((uint64_t)value) & bf_bits_mask(bits);
}

BF_MAYBE_UNUSED static int64_t bf_wrap_add_i64_signed(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_add(&out, ua, ub)) {
        out = ua + ub;
    }
    return bf_wrap_from_u64_signed(out, bits);
}

BF_MAYBE_UNUSED static int64_t bf_wrap_sub_i64_signed(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_sub(&out, ua, ub)) {
        out = ua - ub;
    }
    return bf_wrap_from_u64_signed(out, bits);
}

BF_MAYBE_UNUSED static int64_t bf_wrap_mul_i64_signed(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_mul(&out, ua, ub)) {
        out = ua * ub;
    }
    return bf_wrap_from_u64_signed(out, bits);
}

BF_MAYBE_UNUSED static int64_t bf_wrap_add_i64_unsigned(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_add(&out, ua, ub)) {
        out = ua + ub;
    }
    return bf_wrap_from_u64_unsigned(out, bits);
}

BF_MAYBE_UNUSED static int64_t bf_wrap_sub_i64_unsigned(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_sub(&out, ua, ub)) {
        out = ua - ub;
    }
    return bf_wrap_from_u64_unsigned(out, bits);
}

BF_MAYBE_UNUSED static int64_t bf_wrap_mul_i64_unsigned(int64_t a, int64_t b, unsigned bits) {
    uint64_t ua = bf_wrap_to_u64(a, bits);
    uint64_t ub = bf_wrap_to_u64(b, bits);
    uint64_t out = 0;
    if (ckd_mul(&out, ua, ub)) {
        out = ua * ub;
    }
    return bf_wrap_from_u64_unsigned(out, bits);
}

BF_MAYBE_UNUSED static _Noreturn void bf_diverge_forever(void) {
    for (;;) {
        atomic_signal_fence(memory_order_seq_cst);
    }
}

/* @BF_WRAP_PTR_BEGIN */
BF_MAYBE_UNUSED static ptrdiff_t bf_wrap_ptr(ptrdiff_t ptr, ptrdiff_t delta, ptrdiff_t len) {
    if (len <= 0)
        return 0;
    ptr %= len;
    if (ptr < 0)
        ptr += len;
    delta %= len;
    if (delta < 0)
        delta += len;
    return (ptr + delta) % len;
}
/* @BF_WRAP_PTR_END */

int main(void) {
    enum {
        BF_TAPE_LEN = BF_TEMPLATE_TAPE_LEN,
        BF_CELL_BITS = BF_TEMPLATE_CELL_BITS,
        BF_SIGNED_CELLS = BF_TEMPLATE_SIGNED_CELLS
    };
    /* @BF_CELL_MASK_BEGIN */
    BF_MAYBE_UNUSED static const uint64_t BF_CELL_MASK = BF_TEMPLATE_CELL_MASK;
    /* @BF_CELL_MASK_END */
    /* @BF_INPUT_MASK_BEGIN */
    BF_MAYBE_UNUSED static const uint64_t BF_INPUT_MASK = BF_TEMPLATE_INPUT_MASK;
    /* @BF_INPUT_MASK_END */
    BF_MAYBE_UNUSED static const uint64_t BF_OUTPUT_MASK = BF_TEMPLATE_OUTPUT_MASK;
    int64_t tape[BF_TAPE_LEN] = {};
    ptrdiff_t ptr = 0;
    (void)tape;
    (void)ptr;

    /* @BF_PROGRAM */
    return 0;
}
